{
  "name": "leva-eu-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:seed": "turbo run db:seed",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"**/*.{ts,tsx,md,js,cjs,mjs}\"",
    "prepare": "husky",
    "init": "tsx scripts/init-project.mts"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "chalk": "^5.6.2",
    "execa": "^9.6.1",
    "globby": "^16.2.0",
    "husky": "^9.1.7",
    "hygen": "^6.2.11",
    "inquirer": "^13.4.2",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@9.15.4"
}
