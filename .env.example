# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
DB_USER=admin
DB_PASSWORD=admin_password
DB_NAME=core_db
# URL usada para conexões locais (fora do Docker)
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}?schema=public"

# ------------------------------------------------------------------------------
# SECURITY & AUTH
# ------------------------------------------------------------------------------
JWT_SECRET=core-secret-key-template-change-this

# ------------------------------------------------------------------------------
# STORAGE (MinIO)
# ------------------------------------------------------------------------------
STORAGE_BUCKET=core-bucket
STORAGE_ACCESS_KEY=admin
STORAGE_SECRET_KEY=admin_password
# Endpoint usado para o console/browser
MINIO_PUBLIC_URL=http://localhost:9000

# ------------------------------------------------------------------------------
# FRONTEND (Vite)
# ------------------------------------------------------------------------------
API_URL=http://localhost:3000/api/v1

# ------------------------------------------------------------------------------
# AI ENGINE
# ------------------------------------------------------------------------------
AI_PROVIDER=gemini
AI_API_KEY=YOUR_API_KEY_HERE
